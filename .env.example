# Required: Anthropic API for extraction (Sonnet) and recall (Haiku)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Required for production: Voyage AI for embeddings (voyage-3-lite).
# Not needed when EMBED_STUB=1.
VOYAGE_API_KEY=your_voyage_key_here

# Required: SQLite path inside the container (must be /app/data for the named volume mount)
DB_PATH=/app/data/memory.db

# Optional: if set, all routes require Authorization: Bearer <token>
MEMORY_AUTH_TOKEN=

# Optional: set to 1 to use the deterministic hash-based stub embedder.
# Bypasses Voyage entirely — used by `bun run test:fast` for hermetic testing.
# EMBED_STUB=1
